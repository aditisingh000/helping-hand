## Backend (local development)
NODE_ENV=development
PORT=4000

# Database (when running Postgres via docker-compose at repo root)
DB_HOST=localhost
DB_PORT=5432
DB_USER=helpinghand
DB_PASSWORD=helpinghand
DB_NAME=helpinghand_dev

# Redis (when running Redis via docker-compose at repo root)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# CORS
CORS_ORIGIN=http://localhost:3000
