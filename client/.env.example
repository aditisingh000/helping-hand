## Web client (local development)
## Use the variable that matches your bundler.

# Vite
VITE_API_URL=http://localhost:4000

# Create React App (if used)
REACT_APP_API_URL=http://localhost:4000

# Google Maps (if/when enabled)
VITE_GOOGLE_MAPS_API_KEY=change-me
REACT_APP_GOOGLE_MAPS_API_KEY=change-me
